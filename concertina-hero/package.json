{
  "name": "concertina-hero",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#components/*": "./src/ui/components/*",
    "#modals/*": "./src/ui/modals/*",
    "#screens/*": "./src/ui/screens/*",
    "#engine/*": "./src/engine/*",
    "#songs/*": "./src/songs/*",
    "#instrument/*": "./src/instrument/*",
    "#scoring/*": "./src/scoring/*",
    "#audio/*": "./src/audio/*"
  },
  "description": "A Guitar Hero style rhythm game for toy concertinas, with a paper-mache / Paper Mario look.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --test",
    "test:e2e": "playwright test",
    "typecheck:e2e": "tsc -p e2e --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "prettier": "3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
