{
  "name": "accordion-hero",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#components/*": "./src/ui/components/*",
    "#modals/*": "./src/ui/modals/*",
    "#screens/*": "./src/ui/screens/*",
    "#hooks/*": "./src/hooks/*",
    "#data/*": "./src/data/*",
    "#audio/*": "./src/audio/*"
  },
  "description": "A Guitar Hero style rhythm game for toy accordions, with a paper-mache / Paper Mario look.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "prettier": "3.9.4",
    "vite": "^8.1.3"
  }
}
